APP_NAME=Ampera AI
APP_VERSION=0.1.0
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
# Format:
# postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/ampera

# --- Auth/Secrets (MVP) ---
SECRET_KEY=change-me

# --- Business defaults ---
TARIFF_PER_KWH=1444.70
DEFAULT_LIMIT_KWH=50.0

# --- Agent/LLM ---
# Ollama local does not need an API key. Fill OLLAMA_API_KEY only if your
# Ollama endpoint requires bearer-token authentication.
OLLAMA_MODEL=gpt-oss:120b-cloud
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_API_KEY=
OLLAMA_TEMPERATURE=0.0
ENABLE_SCHEDULER=true
