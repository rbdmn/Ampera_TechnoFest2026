APP_NAME=Ampera AI
APP_VERSION=0.1.0
ENVIRONMENT=development

# --- Database (PostgreSQL) ---
# Format:
# postgresql+psycopg://USER:PASSWORD@HOST:5432/DBNAME
DATABASE_URL=postgresql+psycopg://postgres:password@localhost:5432/ampera

# --- Auth/Secrets (MVP) ---
SECRET_KEY=change-me

# --- CORS ---
# Pisah dengan koma untuk multiple origins
# Contoh production: https://ampera.vercel.app,https://www.ampera.app
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# --- Business defaults ---
TARIFF_PER_KWH=1444.70
DEFAULT_LIMIT_KWH=50.0

# --- LLM (Groq) ---
# Daftar di https://console.groq.com untuk mendapatkan API key gratis.
GROQ_API_KEY=
LLM_MODEL=openai/gpt-oss-120b
LLM_TEMPERATURE=0.0
ENABLE_SCHEDULER=true

# --- Uploads (optional) ---
UPLOADS_DIR=uploads
UPLOADS_PUBLIC_PATH=/static
BACKEND_PUBLIC_BASE_URL=http://localhost:8000
